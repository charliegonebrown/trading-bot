# ═══════════════════════════════════════════════════════════════════════════
# TRADING BOT — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════

# ─── DATABASE ────────────────────────────────────────────────────────────────
# Full PostgreSQL URL — cloud platforms (Railway, Render, Heroku) set this
# automatically. For local Docker Compose it's set in docker-compose.yml.
# Leave blank to fall back to individual PG* variables below.
DATABASE_URL=

# Individual Postgres variables (used only if DATABASE_URL is blank)
PGHOST=localhost
PGPORT=5432
PGUSER=trading_user
PGPASSWORD=trading_pass
PGDATABASE=trading_bot

# ─── BYBIT ───────────────────────────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# ─── ALPACA ──────────────────────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Paper trading URL (safe for testing):
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Live trading URL (real money — use with caution):
# ALPACA_BASE_URL=https://api.alpaca.markets

# ─── GOOGLE GEMINI (optional) ────────────────────────────────────────────────
# Only needed if USE_GEMINI=True in Strategies/ai_strategy.py
GOOGLE_API_KEY=

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins, e.g.:
# ALLOWED_ORIGINS=https://myapp.vercel.app,https://myapp.netlify.app
# Use * for local development only
ALLOWED_ORIGINS=*
